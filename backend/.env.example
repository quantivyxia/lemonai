DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_LOG_LEVEL=INFO
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=300/minute
DRF_THROTTLE_LOGIN=10/minute
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# DB_PROVIDER: sqlite | postgres | mssql (fabric warehouse/sql endpoint)
DB_PROVIDER=sqlite

# SQLite
SQLITE_FILE=db.sqlite3

# PostgreSQL (opcional)
POSTGRES_DB=insighthub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=require
POSTGRES_FORCE_IPV4=False
POSTGRES_HOSTADDR=

# MSSQL / Fabric SQL endpoint (recomendado para Fabric: use Warehouse SQL endpoint)
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DB_NAME=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_EXTRA_PARAMS=Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# Power BI Embedded (futuro)
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
POWERBI_DEFAULT_RLS_ROLE=
POWERBI_RLS_ROLES=
POWERBI_RLS_CUSTOM_DATA_MAX_CHARS=3500
POWERBI_RLS_FALLBACK_ON_IDENTITY_ERROR=false
POWERBI_UPLOAD_TIMEOUT_SECONDS=300
POWERBI_IMPORT_WAIT_TIMEOUT_SECONDS=180
POWERBI_IMPORT_POLL_INTERVAL_SECONDS=2
POWERBI_PBIX_MAX_MB=1024
INSIGHTHUB_ALLOW_DEMO_EMBED_FALLBACK=false
INSIGHTHUB_EMBED_TOKEN_PREFIX=demo-embed-token
